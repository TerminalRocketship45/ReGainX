\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Mean Pearson $r$ across target-angle bins (rows) and severity quartiles (columns) for our combined-trained RecurrentPPO (\textbf  {left}) versus the degeneration-only policy that represents the current state of the art (\textbf  {right}). Both degrade toward Q4 severe and toward small movements (short LSTM context window), but the combined-trained policy retains substantially higher correlation across the grid.}}{8}{figure.caption.10}\protected@file@percent }
\newlabel{fig:heatmap}{{5}{8}{Mean Pearson $r$ across target-angle bins (rows) and severity quartiles (columns) for our combined-trained RecurrentPPO (\textbf {left}) versus the degeneration-only policy that represents the current state of the art (\textbf {right}). Both degrade toward Q4 severe and toward small movements (short LSTM context window), but the combined-trained policy retains substantially higher correlation across the grid}{figure.caption.10}{}}
\newlabel{fig:heatmap@cref}{{[figure][5][]5}{[1][8][]8}{}{}{}}
