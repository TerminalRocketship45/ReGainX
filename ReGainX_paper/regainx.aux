\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Three-phase ReGainX training pipeline, shown with MuJoCo/MyoSuite renders at a fixed $2.0\,\mathrm  {rad}$ target. \textbf  {Phase 1:} a PPO healthy controller (trained) drives the six elbow muscles and reaches the target. \textbf  {Phase 2:} the same controller is frozen and run under combined bradykinesia and muscular degeneration, stalling well short of the target. \textbf  {Phase 3:} a RecurrentPPO exoskeleton agent (trained) supplies assistive torque to the frozen patient, restoring movement to the target. The exoskeleton is trained under domain randomisation over $\approx $20\,000 PD profiles.}}{5}{figure.caption.2}\protected@file@percent }
\newlabel{fig:pipeline}{{2}{5}{Three-phase ReGainX training pipeline, shown with MuJoCo/MyoSuite renders at a fixed $2.0\,\mathrm {rad}$ target. \textbf {Phase 1:} a PPO healthy controller (trained) drives the six elbow muscles and reaches the target. \textbf {Phase 2:} the same controller is frozen and run under combined bradykinesia and muscular degeneration, stalling well short of the target. \textbf {Phase 3:} a RecurrentPPO exoskeleton agent (trained) supplies assistive torque to the frozen patient, restoring movement to the target. The exoskeleton is trained under domain randomisation over $\approx $20\,000 PD profiles}{figure.caption.2}{}}
\newlabel{fig:pipeline@cref}{{[figure][2][]2}{[1][4][]5}{}{}{}}
